library(dplyr)
library(ggplot2)
library(ggh4x)


residuals_df <- as.data.frame(as.table(chisq_res$stdres))
colnames(residuals_df) <- c("Host_family", "Viral_family", "Residual")


host_map_raw <- virus_list %>%
  distinct(Host_species, Host_family, Host_order)


dup_host <- host_map_raw %>%
  distinct(Host_family, Host_order) %>%
  count(Host_family, name = "n_orders") %>%
  filter(n_orders > 1)


host_order_map <- data_freq_filtered2 %>%
  group_by(Host_family, Host_order) %>%
  summarise(weight = sum(Freq), .groups = "drop") %>%
  group_by(Host_family) %>%
  slice_max(order_by = weight, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(Host_family, Host_order)


virus_info <- data_freq_filtered2 %>%
  select(Viral_family.x, Genome) %>%
  distinct()


sig_res <- residuals_df %>%
  filter(abs(Residual) > 2) %>%
  mutate(
    Viral_family = trimws(Viral_family),
    Host_family  = trimws(Host_family)
  ) %>%

  left_join(virus_info, by = c("Viral_family" = "Viral_family.x")) %>%

  left_join(host_order_map, by = "Host_family") %>%

  filter(!is.na(Host_order), !is.na(Genome)) %>%

  distinct(Host_family, Host_order, Viral_family, Genome, .keep_all = TRUE)


chk_dup <- sig_res %>%
  count(Host_family, Viral_family, name = "n_rows") %>%
  filter(n_rows > 1)

if (nrow(chk_dup) > 0) {
  sig_res <- sig_res %>%
    group_by(Host_family, Viral_family) %>%
    slice_max(order_by = abs(Residual), n = 1, with_ties = FALSE) %>%
    ungroup()
}


sig_res$Genome <- factor(sig_res$Genome, levels = c("ssRNA(-)","ssRNA(+)", "dsRNA", "dsDNA", "ssDNA","RT???dsDNA" ))
sig_res$Host_order <- factor(sig_res$Host_order,
                             levels = sort(unique(sig_res$Host_order)))


ggplot(sig_res, aes(x = Viral_family, y = Host_family, fill = Residual)) +
  geom_tile(color = "grey90", linewidth = 0.25) +
  scale_fill_gradient2(
    low = "#4575B4", mid = "white", high = "#D73027",
    limits = c(-5, 5),
    name = "Residual"
  ) +
  facet_grid2(
    rows = vars(Host_order),    
    cols = vars(Genome),         
    scales = "free",
    space  = "free"
  ) +
  theme_minimal(base_size = 12) +
  theme(
    axis.text.x  = element_text(angle = 45, hjust = 1, size = 8),
    axis.text.y  = element_text(size = 9, face = "bold"),
    strip.text.x = element_text(face = "bold", size = 11),
    strip.text.y = element_text(angle = 0, face = "bold", size = 11),
    panel.grid   = element_blank(),
    legend.position = "right"
  ) +
  labs(
    title = "Significant Host–Virus Family Preferences (|Residual| > 2)",
    subtitle = "Faceted by Virus Genome Type (columns) and Host Order (rows)",
    x = "Virus Family",
    y = "Host Family"
  )




sig_res <- sig_res %>%
  mutate(
    Residual_clamped = pmax(pmin(Residual, 5), -5),  
    label_extreme = case_when(
      Residual > 5  ~ ">5",
      Residual < -5 ~ "<-5",
      TRUE ~ ""
    )
  )


p<-ggplot(sig_res, aes(x = Viral_family, y = Host_family, fill = Residual_clamped)) +
  geom_tile(color = "grey90", linewidth = 0.25) +
  geom_text(aes(label = label_extreme), size = 2.5, color = "black", fontface = "bold") +
  scale_fill_gradient2(
    low = "#4575B4", mid = "white", high = "#D73027",
    limits = c(-5, 5),
    name = "Residual"
  ) +
  facet_grid2(
    rows = vars(Host_order),    
    cols = vars(Genome),         
    scales = "free",
    space  = "free"
  ) +
  theme_minimal(base_size = 12) +
  theme(
    axis.text.x  = element_text(angle = 45, hjust = 1, size = 8),
    axis.text.y  = element_text(size = 9, face = "bold"),
    strip.text.x = element_text(face = "bold", size = 11),
    strip.text.y = element_text(angle = 0, face = "bold", size = 11),
    panel.grid   = element_blank(),
    legend.position = "right"
  ) +
  labs(
    title = "Significant Host–Virus Family Preferences (|Residual| > 2)",
    subtitle = "Red = positive preference, Blue = negative preference\nLabeled cells exceed |Residual| > 5",
    x = "Virus Family",
    y = "Host Family"
  )

p


ggsave(
  filename = "Host_Virus_Preference_heatmap-v2.pdf",
  plot = p,
  width = 9,       
  height = 4,      
