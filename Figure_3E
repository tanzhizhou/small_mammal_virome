eco_dir  <- file.path(root_dir, "plots_alpha_3levels")

eco_file   <- "host_with_all_eco_library_level_individual_specific.xlsx"
virus_file <- "副本000-virus_20260310-specific.xlsx"
host_file  <- "副本host_virus-XL-Zone-BoundaryMatch_20260115.xlsx"


library(readxl)
library(dplyr)
library(ggplot2)
library(ggsci)
