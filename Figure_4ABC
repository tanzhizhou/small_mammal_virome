host_phylo <- read.tree("species-name.nwk")
library_species <- host_list$Host_species[match(rownames(virome_matrix), host_list$Library)]
species_in_tree <- library_species[library_species %in% host_phylo$tip.label]
library_in_tree <- rownames(virome_matrix)[library_species %in% host_phylo$tip.label]

phylo_dist_full <- cophenetic(host_phylo)
phylo_dist <- phylo_dist_full[species_in_tree, species_in_tree]
rownames(phylo_dist) <- colnames(phylo_dist) <- library_in_tree
virome_matrix_phylo <- virome_matrix[library_in_tree, ]


host_coords <- host_list %>%
  dplyr::select(Library, lon, lat, zone) %>%
  distinct(Library, .keep_all=TRUE) %>%
  filter(Library %in% library_in_tree) %>%
  arrange(match(Library, library_in_tree))

coords <- host_coords %>% select(lon, lat)
geo_dist <- distm(coords)/1000
rownames(geo_dist) <- host_coords$Library
colnames(geo_dist) <- host_coords$Library


virus_shared <- 1 - vegdist(virome_matrix_phylo, method="jaccard")
virus_shared <- as.matrix(virus_shared)


pairwise_df <- expand.grid(Lib1 = rownames(virome_matrix_phylo),
                           Lib2 = rownames(virome_matrix_phylo)) %>%
  filter(Lib1 != Lib2) %>%
  mutate(
    virus_sim  = mapply(function(x,y) virus_shared[x,y], Lib1, Lib2),
    phylo_dist = mapply(function(x,y) phylo_dist[x,y], Lib1, Lib2),
    geo_dist   = mapply(function(x,y) geo_dist[x,y], Lib1, Lib2)
  ) %>%
  left_join(host_coords %>% dplyr::select(Library, zone), by=c("Lib1"="Library")) %>%
  rename(zone1 = zone) %>%
  left_join(host_coords %>% dplyr::select(Library, zone), by=c("Lib2"="Library")) %>%
  rename(zone2 = zone) %>%
  mutate(same_zone = ifelse(zone1 == zone2, "within_zone", "between_zone"))


mean_phylo_species <- mean(pairwise_df$phylo_dist)
mean_phylo_genus   <- mean(pairwise_df$phylo_dist)  # 可按需要改成 genus 平均


p_e_zone <- ggplot(pairwise_df, aes(x=phylo_dist, y=virus_sim, color=same_zone)) +
  geom_point(alpha=0.1) +
  geom_smooth(method="gam", formula=y~s(x, bs="cs")) +
  geom_vline(xintercept=mean_phylo_species, linetype="dashed") +
  geom_vline(xintercept=mean_phylo_genus, linetype="dashed") +
  labs(x="Host phylogenetic distance (MYA)", y="Virus sharing similarity") +
  theme_minimal() +
  scale_color_manual(values=c("within_zone"="#0c6ba9", "between_zone"="#b33c28"))


p_f_zone <- ggplot(pairwise_df, aes(x=geo_dist, y=virus_sim, color=same_zone)) +
  geom_point(alpha=0.1) +
  geom_smooth(method="gam", formula=y~s(x, bs="cs")) +
  labs(x="Geographic distance (km)", y="Virus sharing similarity") +
  theme_minimal() +
  scale_color_manual(values=c("within_zone"="#0c6ba9", "between_zone"="#b33c28"))



ggsave("phylo_vs_virus_sharing_zone_vsve.png", p_e_zone, width=6, height=4)
ggsave("geo_vs_virus_sharing_zone_vsve.png", p_f_zone, width=6, height=4)
