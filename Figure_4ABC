virus_list <- read_excel("副本000-virus_20260310-ve_vs.xlsx")  
host_list  <- read_excel("副本host_virus-XL-Zone-BoundaryMatch_20260115.xlsx")  


virome_matrix <- virus_list %>%
  dplyr::select(Library, Virus) %>%
  distinct() %>%               
  mutate(presence = 1) %>%
  pivot_wider(names_from = Virus,
              values_from = presence,
              values_fill = list(presence = 0)) %>%
  column_to_rownames("Library")


virome_matrix_unique <- virome_matrix[!duplicated(virome_matrix), ]
library_names <- rownames(virome_matrix)[!duplicated(virome_matrix)]


set.seed(123)
tsne_res <- Rtsne(as.matrix(virome_matrix_unique), perplexity = 30)


virome_order <- virus_list %>%
  dplyr::select(Library, Order) %>%
  distinct(Library, .keep_all = TRUE)



tsne_df <- data.frame(Library = library_names,
                      X = tsne_res$Y[,1],
                      Y = tsne_res$Y[,2]) %>%
  left_join(virome_order, by="Library") %>%
  left_join(host_list %>% dplyr::select(Library, zone), by="Library")



