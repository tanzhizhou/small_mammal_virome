library(dplyr)
library(readxl)

host_list <- read_excel("副本host_virus-XL-Zone-BoundaryMatch_20260115.xlsx")

tsne_anno <- tsne_df %>%
  left_join(
    host_list %>% 
      dplyr::select(Library,
             Host_species,
             Host_order,
             Province,
             County,
             zone),
    by = "Library"
  )

#install.packages("dbscan")
library(dbscan)

set.seed(123)

tsne_clusters <- tsne_anno %>%
  mutate(
    cluster = dbscan(
      tsne_anno[, c("X", "Y")],
      eps = 2.5,      # ?????? 需要你稍微调，2–4 常见
      minPts = 10
    )$cluster
  ) %>%
  filter(cluster != 0)   # 去掉噪声点



cluster_summary <- tsne_clusters %>%
  group_by(cluster) %>%
  summarise(
    n = n(),
    

    top_species = names(sort(table(Host_species), decreasing = TRUE))[1],
    species_prop = max(prop.table(table(Host_species))),
    

    top_county = names(sort(table(County), decreasing = TRUE))[1],
    county_prop = max(prop.table(table(County))),
    
    .groups = "drop"
  ) %>%
  filter(
    n >= 10,              
    species_prop >= 0.5,  
    county_prop  >= 0.5   
  )


tsne_clusters2 <- tsne_clusters %>%
  left_join(
    cluster_summary %>%
      dplyr::select(cluster, top_species, top_county),
    by = "cluster"
  )

label_df <- tsne_clusters2 %>%
  filter(!is.na(top_species)) %>%   
  group_by(cluster) %>%
  summarise(
    X = mean(X),
    Y = mean(Y),
    label = paste0(
      unique(top_county), "\n",
      unique(top_species)
    ),
    .groups = "drop"
  )
label_df

library(ggrepel)

p_tsne_annotated <- ggplot(tsne_clusters, aes(X, Y, color = Order)) +
